# /etc/slurm/cgroup.conf — Tesla DGX-1
# Generated by Ansible. Do NOT edit manually.

CgroupPlugin=cgroup/v2

# Constrain devices (GPUs) to only what SLURM allocates
ConstrainDevices=yes

# Also constrain RAM and CPU to prevent runaway jobs
ConstrainRAMSpace=yes
ConstrainCores=yes

# Enforce memory hard limit (kill job if it exceeds allocation)
AllowedRAMSpace=100
AllowedSwapSpace=0
MaxRAMPercent=100
MaxSwapPercent=100
