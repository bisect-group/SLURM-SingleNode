# =============================================================
# /etc/slurm/slurm.conf — Tesla DGX-1 Single-Node GPU Cluster
# Generated by Ansible. Do NOT edit manually.
# =============================================================

# --- Cluster identity ---
ClusterName={{ cluster_name }}
SlurmctldHost={{ control_machine_hostname }}

# --- Auth ---
AuthType=auth/munge
# AuthAltTypes=auth/jwt
# AuthAltParameters=jwt_key=/etc/slurm/jwt_hs256.key

# --- State & spool ---
StateSaveLocation={{ slurm_spool_dir }}/slurmctld
SlurmdSpoolDir={{ slurm_spool_dir }}/slurmd
SlurmctldPidFile={{ slurm_pid_dir }}/slurmctld.pid
SlurmdPidFile={{ slurm_pid_dir }}/slurmd.pid

# --- Logging ---
SlurmctldLogFile={{ slurm_log_dir }}/slurmctld.log
SlurmdLogFile={{ slurm_log_dir }}/slurmd.log
SlurmctldDebug=info
SlurmdDebug=info

# --- User / group ---
SlurmUser=slurm
SlurmdUser=root

# --- Ports ---
SlurmctldPort=6817
SlurmdPort=6818

# --- Process tracking + cgroup enforcement ---
ProctrackType=proctrack/cgroup
TaskPlugin=task/cgroup,task/affinity

# --- Per-job scratch (TmpFS) ---
TmpFS=/scratch

# --- Job submission filter (Lua) — friendly tier-violation errors ---
JobSubmitPlugins=lua

# --- Scheduling ---
SchedulerType=sched/backfill
SelectType=select/cons_tres
SelectTypeParameters=CR_Core_Memory

# --- Job accounting via slurmdbd ---
AccountingStorageType=accounting_storage/slurmdbd
AccountingStorageHost={{ slurmdbd_storage_host }}
AccountingStoragePort={{ slurmdbd_port }}
AccountingStorageTRES=gres/gpu,gres/gpu:{{ gpu_type }}
AccountingStorageEnforce=qos,limits,safe,associations
JobAcctGatherType=jobacct_gather/cgroup
JobAcctGatherFrequency=30

# --- Job completion log (plus accounting in DB) ---
JobCompType=jobcomp/filetxt
JobCompLoc={{ slurm_log_dir }}/job_completions.log

# --- Multi-factor priority: QoS dominates, age breaks ties (FCFS within QoS) ---
PriorityType=priority/multifactor
PriorityDecayHalfLife=7-0
PriorityFavorSmall=NO
PriorityWeightAge=1000
PriorityWeightFairshare=0
PriorityWeightJobSize=0
PriorityWeightPartition=0
PriorityWeightQOS=10000

# --- Timers ---
SlurmctldTimeout=120
SlurmdTimeout=300
InactiveLimit=0
MinJobAge=300
KillWait=30
Waittime=0

# --- Return codes ---
ReturnToService=2

# --- Array job blast radius ---
MaxArraySize=1000

# =============================================================
# GPU GRES definition
# =============================================================
GresTypes=gpu

# =============================================================
# NODE — DGX-1: 2 sockets × 20 cores × 2 threads = 80 CPUs
# 8x V100 SXM2 32GB, NVLink hybrid cube-mesh
# =============================================================
#

NodeName={{ control_machine_hostname }} Sockets={{ cpu_sockets }} CoresPerSocket={{ cores_per_socket }} ThreadsPerCore={{ threads_per_core }} CPUs={{ total_cpus }} RealMemory={{ real_memory_mb }} Gres=gpu:{{ gpu_type }}:{{ num_gpus }} State=UNKNOWN

# =============================================================
# PARTITION — single 'gpu' partition; tiers enforced via QoS
# =============================================================
PartitionName={{ default_partition }} Nodes={{ partition_nodes }} Default=YES MaxTime={{ max_walltime }} DefaultTime={{ default_walltime }} State=UP OverSubscribe=NO

# Note: there is no MaxSubmitJobsPerUser at the global level here —
# per-user limits are enforced per-tier via QoS (set by slurmdbd_setup).
