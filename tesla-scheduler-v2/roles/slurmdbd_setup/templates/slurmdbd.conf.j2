# /etc/slurm/slurmdbd.conf — Tesla DGX-1
# Generated by Ansible. Do NOT edit manually.
# Contains DB credentials — mode 0600, owner slurm:slurm.

AuthType=auth/munge
DbdAddr=127.0.0.1
DbdHost={{ slurmdbd_storage_host }}
DbdPort={{ slurmdbd_port }}

SlurmUser=slurm
DebugLevel=info
LogFile={{ slurmdbd_log_dir }}/slurmdbd.log
PidFile={{ slurm_pid_dir }}/slurmdbd.pid

# Storage backend
StorageType=accounting_storage/mysql
StorageHost={{ slurmdbd_storage_host }}
StoragePort=3306
StorageUser={{ slurmdbd_db_user }}
StoragePass={{ slurmdbd_db_password }}
StorageLoc={{ slurmdbd_db_name }}

# Archive policy: keep accounting forever; let admins prune if they wish.
ArchiveJobs=no
ArchiveSteps=no
ArchiveSuspend=no
PurgeEventAfter=24months
PurgeJobAfter=24months
PurgeStepAfter=24months
PurgeSuspendAfter=24months
