# /etc/pam.d/sshd — Modified to enforce SLURM job context
# Generated by Ansible. Do NOT edit manually.
#
# pam_slurm_adopt: if a user SSHs in and tries to run GPU code
# outside a job allocation, pam_slurm_adopt will block or adopt
# the session into an existing allocation. Combined with cgroup
# device constraints, direct GPU access is prevented.

# Standard auth stack
@include common-auth

# --- SLURM adoption ---
# "require" means: user MUST have a running SLURM allocation to SSH
# into and run GPU-capable processes. Use "use_first_pass" to avoid
# double password prompts.
#
# For stricter enforcement (block SSH entirely without a job):
#   account required pam_slurm_adopt.so
#
# For softer enforcement (adopt into existing job if one exists):
#   account sufficient pam_slurm_adopt.so
#
# We use "sufficient" here so admins can still log in freely.
# Only GPU access is blocked at the cgroup level regardless.
account sufficient pam_slurm_adopt.so

@include common-account
@include common-session
@include common-password

session required pam_limits.so
session optional pam_motd.so motd=/etc/motd
session optional pam_motd.so noupdate
