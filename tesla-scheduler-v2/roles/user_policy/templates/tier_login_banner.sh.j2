# Tesla DGX-1 — per-login tier banner
# Sourced from /etc/profile.d for interactive login shells
# Generated by Ansible.

# Skip for non-login or non-interactive shells, and skip for root
if [ -z "${PS1:-}" ]; then return 0 2>/dev/null || exit 0; fi
if [ "$(id -u)" = "0" ]; then return 0 2>/dev/null || exit 0; fi

# Skip if user isn't in tesla_users (random system accounts)
if ! id -nG 2>/dev/null | tr ' ' '\n' | grep -qx tesla_users; then
    return 0 2>/dev/null || exit 0
fi

# Determine the user's tier by Unix group membership
_tesla_user_tier="(unassigned)"
_tesla_max_gpus="?"
_tesla_max_cpus="?"
_tesla_max_jobs="?"

_user_groups=$(id -nG 2>/dev/null)

{% for t in tesla_tiers | reverse %}
if echo " $_user_groups " | grep -q " tesla-{{ t.name }} "; then
    _tesla_user_tier="{{ t.name }}"
    _tesla_max_gpus="{{ t.max_gpus }}"
    _tesla_max_cpus="{{ t.max_cpus }}"
    _tesla_max_jobs="{{ t.max_jobs }}"
fi
{% endfor %}

_active=$(squeue -h -u "$USER" 2>/dev/null | wc -l)

printf "\n"
printf "  Your tier:    %s\n" "$_tesla_user_tier"
printf "  Max GPUs/job: %s   Max CPUs/job: %s   Max jobs queued: %s\n" \
    "$_tesla_max_gpus" "$_tesla_max_cpus" "$_tesla_max_jobs"
printf "  Active jobs:  %s\n" "$_active"
if [ "$_tesla_user_tier" = "(unassigned)" ]; then
    printf "\n  WARNING: you have no tier assigned. GPU jobs will be rejected.\n"
    printf "  Contact a slurm_admin (see 'getent group slurm_admins') to be added to a tier.\n"
fi
printf "\n"

unset _tesla_user_tier _tesla_max_gpus _tesla_max_cpus _tesla_max_jobs _user_groups _active
