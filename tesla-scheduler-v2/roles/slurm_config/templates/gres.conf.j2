# /etc/slurm/gres.conf — GPU GRES configuration for Tesla DGX-1
# Generated by Ansible. Do NOT edit manually.
#
# DGX-1 NVLink topology (from nvidia-smi topo -m, May 2026):
#   GPUs 0-3  → CPU socket 0 → cores 0-19,40-59  → NUMA node 0
#   GPUs 4-7  → CPU socket 1 → cores 20-39,60-79 → NUMA node 1
#   Intra-baseboard pairs (NV1/NV2) use NVLink
#   Cross-baseboard pairs (e.g. 0↔4) traverse QPI (SYS) — avoid pairing
#
# HOW TO RE-VERIFY YOUR GPU BUS IDs (after kernel/driver changes):
#   nvidia-smi --query-gpu=index,pci.bus_id --format=csv,noheader
#
# Cores= bind tells SLURM which CPU cores are local to each GPU. With
# task/affinity + --gres-flags=enforce-binding, jobs allocated GPU N will
# only run on the matching socket's cores — avoiding QPI traffic for the
# common case of single-NUMA-node jobs.

# --- NUMA node 0 (CPU socket 0): GPUs 0-3 ---
Name=gpu Type={{ gpu_type }} File=/dev/nvidia0 Cores=0-19
Name=gpu Type={{ gpu_type }} File=/dev/nvidia1 Cores=0-19
Name=gpu Type={{ gpu_type }} File=/dev/nvidia2 Cores=0-19
Name=gpu Type={{ gpu_type }} File=/dev/nvidia3 Cores=0-19

# --- NUMA node 1 (CPU socket 1): GPUs 4-7 ---
Name=gpu Type={{ gpu_type }} File=/dev/nvidia4 Cores=20-39
Name=gpu Type={{ gpu_type }} File=/dev/nvidia5 Cores=20-39
Name=gpu Type={{ gpu_type }} File=/dev/nvidia6 Cores=20-39
Name=gpu Type={{ gpu_type }} File=/dev/nvidia7 Cores=20-39
